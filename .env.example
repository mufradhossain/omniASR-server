# omniASR Server Configuration
# Copy to .env and modify as needed

# ===========================================
# Model Settings
# ===========================================
# Available models:
#   omniASR_CTC_300M_v2   — fastest, lowest quality
#   omniASR_CTC_1B_v2
#   omniASR_CTC_7B_v2
#   omniASR_LLM_1B_v2
#   omniASR_LLM_7B_v2     — best quality (recommended with quantization)
MODEL_CARD=omniASR_LLM_7B_v2

# Language: eng_Latn, or set to empty for auto-detect
# Options: eng_Latn, fra_Latn, deu_Latn, spa_Latn, etc.
DEFAULT_LANG=eng_Latn

# Device: cuda, cpu, or leave empty for auto-detect
DEVICE=cuda

# ===========================================
# Quantization Settings
# ===========================================
# Enable quantization (loads full-module pickle — no 29 GB fairseq2 download)
QUANT_ENABLED=true

# Quantization type: nf4 (4-bit, recommended)
QUANT_TYPE=nf4

# Checkpoint directory — place the downloaded .pt file here
# Download from: https://huggingface.co/sheikhmufrad/omniASR-LLM-7B-v2-quantized
QUANT_CHECKPOINT_PATH=/app/checkpoints

# ===========================================
# Server Settings
# ===========================================
HOST=0.0.0.0
PORT=8000

# Concurrent connection limits
MAX_CONCURRENT_REQUESTS=100
MAX_WEBSOCKET_CONNECTIONS=50

# ===========================================
# Streaming Settings
# ===========================================
# Chunk duration in seconds (higher = better quality, more latency)
CHUNK_DURATION=5.0

# Voice Activity Detection (set to false when using external VAD like Pipecat)
VAD_ENABLED=true
